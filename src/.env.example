APP_NAME="Montagna Servizi SCPA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — MariaDB (Docker: host = nome servizio "db")
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ms_laravel
DB_USERNAME=ms_user
DB_PASSWORD=ms_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Mail / SMTP (Brevo transazionale)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@montagnaservizi.com"
MAIL_FROM_NAME="Montagna Servizi SCPA"

# -----------------------------------------------------------------------
# Integrazioni esterne — configurabili senza toccare il codice
# -----------------------------------------------------------------------

# Typeform — form manifestazioni di interesse
# URL finale: https://form.typeform.com/to/{TYPEFORM_FORM_ID}?source={slug}
TYPEFORM_FORM_ID=PLACEHOLDER

# Brevo — iscrizione newsletter nel footer
# Opzione A: incolla qui il codice embed HTML completo fornito da Brevo
BREVO_EMBED_CODE=
# Opzione B: usa l'API Brevo per sottoscrizioni programmatiche
BREVO_API_KEY=
BREVO_LIST_ID=

# Google Tag Manager
GTM_CONTAINER_ID=

# Cookie banner (true = attivo, false = disabilitato)
COOKIE_BANNER_ENABLED=true

# UAT
UAT_URL=https://uat.montagnaservizi.com
