# ============================================================
# .env.uat — Ambiente UAT (staging)
# Copia questo file in .env.uat e compila i valori reali.
# NON committare .env.uat — è escluso da .gitignore (.env.*)
# ============================================================

APP_NAME="Montagna Servizi SCPA"
APP_ENV=staging
# Genera con: docker compose exec app php artisan key:generate --show
APP_KEY=base64:CHANGE_ME
APP_DEBUG=false
APP_URL=https://uat.montagnaservizi.com

LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# ── Database ──────────────────────────────────────────────────
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ms_laravel
DB_USERNAME=ms_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_STRONG_PASSWORD

# ── Cache / Session ───────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

# ── Typeform ─────────────────────────────────────────────────
# Inserire il Form ID reale da typeform.com
TYPEFORM_FORM_ID=PLACEHOLDER
TYPEFORM_BASE_URL=https://form.typeform.com/to

# ── Brevo newsletter ──────────────────────────────────────────
# API key da app.brevo.com → API keys
BREVO_API_KEY=
# ID della lista contatti Brevo (numero intero)
BREVO_LIST_ID=
BREVO_EMBED_CODE=

# ── Google Tag Manager ────────────────────────────────────────
# Es. GTM-XXXXXXX
GTM_CONTAINER_ID=

# ── Cookie banner ─────────────────────────────────────────────
COOKIE_BANNER_ENABLED=true

# ── Mail (opzionale — per notifiche future) ───────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@montagnaservizi.com
MAIL_FROM_NAME="Montagna Servizi SCPA"
