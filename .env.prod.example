# ============================================================
# .env.prod — Ambiente Produzione
# Copia in .env.prod e compila i valori reali.
# NON committare .env.prod — escluso da .gitignore (.env.*)
# ============================================================

APP_NAME="Montagna Servizi SCPA"
APP_ENV=production
APP_KEY=base64:CHANGE_ME
APP_DEBUG=false
APP_URL=https://www.montagnaservizi.com

LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ms_laravel_prod
DB_USERNAME=ms_user_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_STRONG_PASSWORD

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

TYPEFORM_FORM_ID=CHANGE_ME
TYPEFORM_BASE_URL=https://form.typeform.com/to

BREVO_API_KEY=CHANGE_ME
BREVO_LIST_ID=CHANGE_ME
BREVO_EMBED_CODE=

GTM_CONTAINER_ID=CHANGE_ME
COOKIE_BANNER_ENABLED=true

MAIL_MAILER=smtp
MAIL_HOST=smtp.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@montagnaservizi.com
MAIL_FROM_NAME="Montagna Servizi SCPA"
